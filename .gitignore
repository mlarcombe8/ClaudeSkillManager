# ClaudeSkillManager activity logs live in ~/.csm/ (outside this repo).
# These rules guard against a log ever being created/committed inside the repo.
.csm/
csm.log
*.log

# Python bytecode cache (from running the suite's scripts)
__pycache__/
*.pyc

# Session handoffs (written by /session-handoff save) are personal-context
# files for picking the project up in a new session; they stay local.
HANDOFF.md
